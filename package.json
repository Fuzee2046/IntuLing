{
  "name": "intuling",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev:web": "npm --prefix frontend run dev",
    "dev:api": "uv --directory backend run uvicorn intuling_api.main:app --reload --host 127.0.0.1 --port 8000",
    "build:web": "npm --prefix frontend run build",
    "test:web": "npm --prefix frontend run test",
    "test:api": "uv --directory backend run pytest",
    "lint:web": "npm --prefix frontend run lint",
    "lint:api": "uv --directory backend run ruff check .",
    "format:api": "uv --directory backend run ruff format .",
    "migrate:api": "uv --directory backend run alembic upgrade head"
  }
}
